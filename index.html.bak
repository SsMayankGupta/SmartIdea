</section>

<section class="quiz-section">
  <div class="quiz-wrapper">
    <h2>♻ Smart Recycling Challenge</h2>
    <p class="quiz-sub">Test your recycling knowledge and earn green points!</p>
    <div class="quiz-card">
      <div class="score-badge">Green Points: <span id="scoreValue">0</span></div>
      <div class="quiz-progress">Question <span id="questionNumber">1</span> / 5</div>
      <div class="progress-bar">
        <div class="progress-fill" id="progressFill" style="width: 20%"></div>
      </div>
      <h3 id="questionText">Loading question...</h3>
      <div class="options-container" id="optionsContainer">
        <button class="option-btn">Option 1</button>
        <button class="option-btn">Option 2</button>
        <button class="option-btn">Option 3</button>
        <button class="option-btn">Option 4</button>
      </div>
      <div id="feedback"></div>
      <button id="nextBtn" style="display:none;">Next Question</button>
      <div id="finalResult" style="display:none;">
        <h3 id="scoreText"></h3>
        <button id="restartBtn">Restart Quiz</button>
      </div>
    </div>
  </div>
</section>

