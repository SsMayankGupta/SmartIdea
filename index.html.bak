<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>EcoConnect | Waste Management Solutions</title>

  <!-- Google Fonts - Montserrat & Cinzel -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">

  <!-- Font Awesome Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    * {
      font-family: 'Montserrat', sans-serif;
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      min-height: 100vh;
      background: linear-gradient(135deg, #0b5d3b 0%, #1a8c5e 50%, #2ecc71 100%);
      color: #ffffff;
    }

    /* HEADER */
    header {
      background: rgba(11, 93, 59, 0.3);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(255, 255, 255, 0.2);
      padding: 15px 30px;
      position: sticky;
      top: 0;
      z-index: 1000;
    }

    .header-container {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .logo {
      font-family: 'Cinzel', serif;
      font-size: 24px;
      font-weight: 700;
      color: #ffffff;
      text-decoration: none;
      letter-spacing: 2px;
    }

    /* NAVIGATION */
    .nav-links {
      display: flex;
      list-style: none;
      gap: 30px;
    }

    .nav-links a {
      color: rgba(255, 255, 255, 0.9);
      text-decoration: none;
      font-weight: 500;
      font-size: 14px;
      transition: all 0.3s ease;
      position: relative;
    }

    .nav-links a:hover,
    .nav-links a.active {
      color: #ffffff;
    }

    .nav-links a::after {
      content: '';
      position: absolute;
      bottom: -4px;
      left: 0;
      width: 0;
      height: 2px;
      background: #7dffb3;
      transition: width 0.3s ease;
    }

    .nav-links a:hover::after,
    .nav-links a.active::after {
      width: 100%;
    }

    /* DROPDOWN */
    .dropdown {
      position: relative;
    }

    .mega-menu {
      position: absolute;
      top: 100%;
      left: 0;
      background: rgba(11, 93, 59, 0.95);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 16px;
      padding: 20px;
      min-width: 500px;
      display: none;
      flex-direction: row;
      gap: 20px;
      margin-top: 10px;
    }

    .dropdown:hover .mega-menu {
      display: flex;
    }

    .mega-left {
      display: flex;
      gap: 20px;
    }

    .mega-column {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .mega-column h4 {
      color: #7dffb3;
      font-size: 14px;
      margin-bottom: 5px;
    }

    .mega-column a {
      font-size: 12px;
      padding: 5px 0;
    }

    .mega-column a::after {
      display: none;
    }

    .mega-right {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 10px;
    }

    .mega-right img {
      width: 100px;
      height: 100px;
      object-fit: cover;
      border-radius: 12px;
      margin-bottom: 10px;
    }

    .mega-right h3 {
      font-size: 14px;
      margin-bottom: 5px;
    }

    .mega-right p {
      font-size: 11px;
      color: rgba(255, 255, 255, 0.8);
    }

    .mega-btn {
      background: linear-gradient(135deg, #7dffb3, #2ecc71);
      color: #0b5d3b;
      padding: 8px 16px;
      border-radius: 8px;
      font-size: 12px;
      font-weight: 600;
      margin-top: 10px;
      text-decoration: none;
    }

    /* NAV ACTIONS */
    .nav-actions {
      display: flex;
      gap: 15px;
      align-items: center;
    }

    .nav-actions a {
      text-decoration: none;
      font-size: 14px;
      font-weight: 600;
      transition: all 0.3s ease;
    }

    .login {
      color: #ffffff;
    }

    .signup-btn {
      background: linear-gradient(135deg, #7dffb3, #2ecc71);
      color: #0b5d3b;
      padding: 10px 24px;
      border-radius: 25px;
    }

    .signup-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 5px 15px rgba(125, 255, 179, 0.3);
    }

    /* MOBILE MENU */
    .mobile-menu-btn {
      display: none;
      background: none;
      border: none;
      color: #ffffff;
      font-size: 24px;
      cursor: pointer;
    }

    /* HERO SECTION */
    .hero {
      min-height: 80vh;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 40px 20px;
    }

    .hero-content h1 {
      font-family: 'Cinzel', serif;
      font-size: 4rem;
      font-weight: 700;
      margin-bottom: 20px;
      letter-spacing: 4px;
    }

    .hero-content h1 span {
      color: #7dffb3;
    }

    .hero-content p {
      font-size: 1.3rem;
      color: rgba(255, 255, 255, 0.9);
      margin-bottom: 40px;
    }

    .hero-buttons {
      display: flex;
      gap: 20px;
      justify-content: center;
      flex-wrap: wrap;
    }

    .hero-btn-primary, .hero-btn-secondary {
      padding: 18px 40px;
      border-radius: 50px;
      font-size: 1rem;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.3s ease;
      border: none;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .hero-btn-primary {
      background: linear-gradient(135deg, #7dffb3, #2ecc71);
      color: #0b5d3b;
    }

    .hero-btn-secondary {
      background: transparent;
      color: #ffffff;
      border: 2px solid rgba(255, 255, 255, 0.5);
    }

    .hero-btn-primary:hover, .hero-btn-secondary:hover {
      transform: translateY(-3px);
      box-shadow: 0 15px 30px rgba(0, 0, 0, 0.3);
    }

    /* GET STARTED SECTION */
    .get-started {
      padding: 80px 20px;
      background: transparent;
    }

    .gs-container {
      max-width: 1100px;
      margin: 0 auto;
      text-align: center;
    }

    .gs-container h2 {
      font-family: 'Cinzel', serif;
      font-size: 2.5rem;
      margin-bottom: 10px;
    }

    .gs-subtitle {
      font-size: 1.1rem;
      color: rgba(255, 255, 255, 0.8);
      margin-bottom: 40px;
    }

    .gs-content {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 30px;
      margin-bottom: 40px;
    }

    .gs-card {
      background: transparent;
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 20px;
      padding: 30px;
      text-align: left;
      transition: all 0.3s ease;
    }

    .gs-card:hover {
      transform: translateY(-5px);
      background: rgba(255, 255, 255, 0.05);
    }

    .gs-card h3 {
      font-size: 1.2rem;
      margin-bottom: 15px;
      color: #ffffff;
    }

    .gs-card p {
      font-size: 0.95rem;
      color: rgba(255, 255, 255, 0.85);
      line-height: 1.6;
    }

    .gs-cta {
      display: flex;
      gap: 20px;
      justify-content: center;
      flex-wrap: wrap;
    }

    .gs-btn-primary, .gs-btn-secondary {
      padding: 16px 40px;
      border-radius: 50px;
      font-size: 1rem;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.3s ease;
      border: none;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .gs-btn-primary {
      background: linear-gradient(135deg, #7dffb3, #2ecc71);
      color: #0b5d3b;
    }

    .gs-btn-secondary {
      background: transparent;
      color: #ffffff;
      border: 2px solid rgba(255, 255, 255, 0.5);
    }

    .gs-btn-primary:hover, .gs-btn-secondary:hover {
      transform: translateY(-3px);
      box-shadow: 0 15px 30px rgba(0, 0, 0, 0.3);
    }

    /* QUICK OPTIONS CARDS */
    .quick-options {
      padding: 60px 20px;
      display: flex;
      gap: 25px;
      justify-content: center;
      flex-wrap: wrap;
      max-width: 1200px;
      margin: 0 auto;
    }

    .option-card {
      background: rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 24px;
      padding: 35px;
      text-align: center;
      width: 220px;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .option-card:hover {
      transform: translateY(-10px);
      background: rgba(255, 255, 255, 0.15);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
    }

    .option-card img {
      width: 70px;
      height: 70px;
      margin-bottom: 20px;
      filter: brightness(0) invert(1);
    }

    .impact-card p {
      color: rgba(255, 255, 255, 0.8);
      font-size: 0.95rem;
      line-height: 1.6;
    }

    /* STATS SECTION */
    .sustainability {
      padding: 80px 20px;
      text-align: center;
    }
        <h3>🌱 Our Mission</h3>
        <p>EcoConnect bridges the gap between citizens and sustainable waste solutions. We make recycling accessible, reporting effortless, and environmental action rewarding.</p>
      </div>
      <div class="gs-card">
        <h3>♻️ Why It Matters</h3>
        <p>Proper waste management reduces pollution, conserves natural resources, prevents disease spread, and creates cleaner, healthier communities for future generations.</p>
      </div>
      <div class="gs-card">
        <h3>🌍 Our Impact</h3>
        <p>Join thousands of citizens transforming waste into resources. Every item recycled, every report filed, and every service booked brings us closer to a zero-waste future.</p>
      </div>
    </div>
    <div class="gs-cta">
      <button onclick="location.href='services/services.html'" class="gs-btn-primary">Explore Our Services</button>
      <button onclick="location.href='auth/signup.html'" class="gs-btn-secondary">Join the Movement</button>
    </div>
  </div>
</section>

<section class="quick-options">
  <div class="option-card" onclick="location.href='pages/dispose.html'">
    <img src="https://cdn-icons-png.flaticon.com/512/679/679922.png" alt="Dispose">
    <h3>Dispose Smartly</h3>
    <p>Learn How to Recycle</p>
  </div>
  <div class="option-card" onclick="location.href='pages/report.html'">
    <img src="https://cdn-icons-png.flaticon.com/512/564/564619.png" alt="Report">
    <h3>Report a Problem</h3>
    <p>Report an Issue</p>
  </div>
  <div class="option-card" onclick="location.href='pages/centers.html'">
    <img src="https://cdn-icons-png.flaticon.com/512/684/684908.png" alt="Centers">
    <h3>Nearby Recyclers</h3>
    <p>Find Centers</p>
  </div>
  <div class="option-card" onclick="location.href='pages/rewards.html'">
    <img src="https://cdn-icons-png.flaticon.com/512/2907/2907253.png" alt="Rewards">
    <h3>Earn Rewards</h3>
    <p>Get Green Points</p>
  </div>
</section>

<section class="quick-access">
  <div class="quick-box" onclick="location.href='pages/dashboard.html'">
    <h3>📊 Track Requests</h3>
    <p>View status of your waste pickup requests</p>
  </div>
  <div class="quick-box" onclick="location.href='pages/dashboard.html'">
    <h3>🌱 Track Green Points</h3>
    <p>Check rewards earned for eco-friendly actions</p>
  </div>
</section>

<section class="solutions-section" id="solutions">
  <h2>Our Solutions</h2>
  <div class="wm-cards">
    <div class="wm-card">
      <div class="wm-img">
        <img src="images/resi_waste.png" alt="Residential">
      </div>
      <h3>Residential Waste Pickup</h3>
      <p>Scheduled doorstep waste collection and recycling services for households, ensuring clean, hygienic, and sustainable neighborhoods.</p>
      <a href="education/residential-recycling.html" class="wm-link">Explore Residential Waste Services →</a>
    </div>
    <div class="wm-card">
      <div class="wm-img">
        <img src="images/office-recycling.png" alt="Commercial">
      </div>
